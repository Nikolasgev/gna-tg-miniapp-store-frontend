{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "git clone https://github.com/flutter/flutter.git -b beta --depth 1 .flutter-sdk && .flutter-sdk/bin/flutter config --enable-web --no-analytics",
  "buildCommand": ".flutter-sdk/bin/flutter pub get && .flutter-sdk/bin/flutter build web --release --target lib/mini_app/main.dart --dart-define=API_BASE_URL=${API_BASE_URL:-https://gnatgminiapp-production.up.railway.app} --dart-define=ENVIRONMENT=production",
  "outputDirectory": "build/web"
}
